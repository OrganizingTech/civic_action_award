<div id="<%= dom_id advocate %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">First name:</strong>
    <%= advocate.first_name %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Last hame:</strong>
    <%= advocate.last_hame %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Email:</strong>
    <%= advocate.email %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Zipcode:</strong>
    <%= advocate.zipcode %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this advocate", advocate, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this advocate', edit_advocate_path(advocate), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
